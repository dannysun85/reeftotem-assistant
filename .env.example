# 腾讯云语音服务配置
# 请复制此文件为 .env 并填入您的实际配置值

# 腾讯云 API 密钥 ID (必需)
# 从腾讯云控制台 > 访问管理 > API密钥管理 获取
# 示例格式: AKIDxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TENCENT_SECRET_ID=AKIDexample1234567890abcdef

# 腾讯云 API 密钥 Key (必需)
# 从腾讯云控制台 > 访问管理 > API密钥管理 获取
# 示例格式: xxxxxxxxxxxxxxxxxxxxxx
VITE_TENCENT_SECRET_KEY=example1234567890abcdef

# 腾讯云服务区域 (可选，默认: ap-beijing)
# 可选值:
# ap-beijing    - 北京
# ap-shanghai  - 上海
# ap-guangzhou - 广州
# ap-chengdu   - 成都
# ap-singapore - 新加坡
# ap-hongkong  - 香港
VITE_TENCENT_REGION=ap-beijing

# 腾讯云应用 ID (必需)
# 从语音识别/语音合成服务控制台获取
# 示例格式: 1234567890 (数字ID)
VITE_TENCENT_APP_ID=1234567890

# ===============================================
# 语音识别 (ASR) 配置示例
# ===============================================

# 腾讯云一句话识别服务
# 控制台地址: https://console.cloud.tencent.com/asr
# 开通步骤:
# 1. 登录腾讯云控制台
# 2. 搜索"语音识别"
# 3. 开通"一句话识别"服务
# 4. 获取应用ID

# 测试环境配置示例:
# VITE_TENCENT_SECRET_ID=AKIDtest1234567890abcdef
# VITE_TENCENT_SECRET_KEY=testkey1234567890abcdef
# VITE_TENCENT_REGION=ap-beijing
# VITE_TENCENT_APP_ID=1234567890

# ===============================================
# 语音合成 (TTS) 配置示例
# ===============================================

# 腾讯云语音合成服务
# 控制台地址: https://console.cloud.tencent.com/tts
# 开通步骤:
# 1. 登录腾讯云控制台
# 2. 搜索"语音合成"
# 3. 开通"基础语音合成"服务
# 4. 获取应用ID (通常与ASR相同)

# ===============================================
# 生产环境配置检查清单
# ===============================================

# 1. ✅ 确认腾讯云账号已实名认证
# 2. ✅ 确认账户余额充足 (推荐 >= 100元)
# 3. ✅ 已开通语音识别服务 (一句话识别)
# 4. ✅ 已开通语音合成服务 (基础语音合成)
# 5. ✅ API密钥权限正确 (支持 ASR 和 TTS)
# 6. ✅ 应用 ID 有效且对应相应服务
# 7. ✅ 服务区域选择正确

# ===============================================
# AI大模型配置 (可选)
# ===============================================

# AI服务提供商
# 可选值: ollama, openai, anthropic, local
# ollama: 本地Ollama服务 (推荐)
# openai: OpenAI GPT模型
# anthropic: Claude模型
# local: 本地简单回复 (降级方案)
VITE_AI_PROVIDER=ollama

# Ollama配置 (当provider=ollama时使用)
# 默认本地Ollama服务地址
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Ollama模型名称
# 推荐中文模型:
# - qwen2.5:7b (千问2.5 7B，推荐)
# - qwen2:7b (千问2 7B)
# - llama3.1:8b (Llama 3.1 8B)
# - gemma2:9b (Gemma 2 9B)
VITE_OLLAMA_MODEL=qwen2.5:7b

# OpenAI配置 (当provider=openai时使用)
# VITE_OPENAI_API_KEY=your-openai-api-key
# VITE_OPENAI_MODEL=gpt-3.5-turbo

# Anthropic Claude配置 (当provider=anthropic时使用)
# VITE_ANTHROPIC_API_KEY=your-claude-api-key
# VITE_ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI模型参数
VITE_AI_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=1000

# ===============================================
# 免费额度说明
# ===============================================

# 腾讯云语音服务提供免费额度:
# - 语音识别: 每月免费调用次数
# - 语音合成: 每月免费字符数
# 具体额度请参考腾讯云控制台

# Ollama本地模型:
# - 完全免费运行
# - 需要本地硬件支持

# ===============================================
# 成本预估 (仅供参考)
# ===============================================

# 语音识别 (一句话识别):
# - 约 0.6元/次
# - 建议控制使用频率

# 语音合成:
# - 约 2-3元/万字符
# - 根据语音类型和长度计费

# ===============================================
# 调试和监控
# ===============================================

# 启用详细调试日志 (true/false)
VITE_DEBUG_VOICE=false

# 启用AI对话日志 (true/false)
VITE_DEBUG_AI=false

# 启用Live2D调试信息 (true/false)
VITE_DEBUG_LIVE2D=false

# 日志级别: error, warn, info, debug
VITE_LOG_LEVEL=info

# ===============================================
# 使用指南
# ===============================================

# 1. 基础配置 (必需):
#    - 配置腾讯云API密钥
#    - 确保麦克风权限

# 2. AI模型配置 (推荐):
#    - 安装Ollama: brew install ollama
#    - 启动服务: ollama serve
#    - 下载模型: ollama pull qwen2.5:7b

# 3. 测试步骤:
#    - 启动应用: pnpm tauri dev
#    - 检查服务状态页面
#    - 点击录音按钮测试

# 4. 调试模式:
#    - 设置 VITE_DEBUG_VOICE=true
#    - 打开浏览器开发者工具
#    - 查看控制台日志

# 关键日志标识:
# 🎙️ ASR调用开始
# 🤖 AI回复生成
# 🔊 TTS调用开始
# 🎭 Live2D口型同步
# ✅ 服务调用成功
# ❌ 服务调用失败